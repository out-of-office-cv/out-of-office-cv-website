---
import BaseLayout from "../layouts/BaseLayout.astro"
import PollieList from "../components/PollieList.svelte"
import { getCollection } from "astro:content"
import { getPolliesByDecade } from "../content.config"

const allPollies = await getCollection("pollies")
const polliesByDecade = getPolliesByDecade(allPollies)
---

<BaseLayout>
  <section class="lede">
    <p class="lede-para">
      Australia has a strong democracy, and we need to make a conscious effort
      to keep it that way. While we have systems that track our representatives
      while they are in office, there is very little organised information
      about what happens after they leave. By making this data clear,
      accessible, and easy to understand, we can help close the gap and
      support transparency and public discourse.
    </p>
    <p class="lede-para">
      Politicians are free to choose their post-parliament careers, but those
      choices reveal what they value. This project helps you decide whether
      that aligns with you.
    </p>
  </section>

  <PollieList polliesByDecade={polliesByDecade} client:load />
</BaseLayout>

<style>
  .lede {
    max-width: var(--measure-reading);
    margin-bottom: var(--space-2xl);
  }

  .lede-para {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--color-ink);
  }

  .lede-para:first-child::first-letter {
    font-weight: 600;
  }
</style>
