---
import BaseLayout from "../layouts/BaseLayout.astro"
import DirectoryFilters from "../components/DirectoryFilters.svelte"
import PollieDirectory from "../components/PollieDirectory.astro"
import { getCollection } from "astro:content"
import { getPolliesByDecade } from "../content.config"

const allPollies = await getCollection("pollies")
const polliesByDecade = getPolliesByDecade(allPollies)

const decades = polliesByDecade.map((g) => g.decade)
const stateSet = new Set<string>()
const partySet = new Set<string>()
for (const group of polliesByDecade) {
  for (const p of group.pollies) {
    if (p.state) stateSet.add(p.state)
    if (p.party) partySet.add(p.party.trim())
  }
}
const states = Array.from(stateSet).sort()
const parties = Array.from(partySet).sort()
---

<BaseLayout>
  <h1 class="visually-hidden">Out of Office CV — directory</h1>
  <section class="lede" aria-label="About this project">
    <p class="lede-para">
      Australia has a strong democracy, and we need to make a conscious effort
      to keep it that way. While we have systems that track our representatives
      while they are in office, there is very little organised information
      about what happens after they leave. By making this data clear,
      accessible, and easy to understand, we can help close the gap and
      support transparency and public discourse.
    </p>
    <p class="lede-para">
      Politicians are free to choose their post-parliament careers, but those
      choices reveal what they value. This project helps you decide whether
      that aligns with you.
    </p>
  </section>

  <DirectoryFilters {decades} {states} {parties} client:load />
  <PollieDirectory polliesByDecade={polliesByDecade} />
  <p class="empty-state" hidden>
    <em>No entries match those filters.</em>
  </p>
</BaseLayout>

<style>
  .lede {
    max-width: var(--measure-reading);
    margin-bottom: var(--space-2xl);
  }

  .lede-para {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--color-ink);
  }

  .lede-para:first-child::first-letter {
    font-weight: 600;
  }

  .empty-state {
    font-family: var(--font-serif-stack);
    font-size: 1.05rem;
    color: var(--color-ink-2);
    padding: var(--space-xl) 0;
    max-width: var(--measure-reading);
  }
</style>
