---
import BaseLayout from "../../layouts/BaseLayout.astro"
import PollieHeader from "../../components/PollieHeader.astro"
import GigList from "../../components/GigList.astro"
import PollieSearch from "../../components/PollieSearch.svelte"
import { getCollection } from "astro:content"
import { formatDate, timeAgo } from "../../utils"
import type { Pollie, Gig } from "../../types"

type PollieData = Pollie & { gigCount: number; gigs: Gig[] }

export async function getStaticPaths() {
  const pollies = await getCollection("pollies")
  return pollies.map((pollie: { data: PollieData }) => ({
    params: { slug: pollie.data.slug },
    props: { pollie: pollie.data },
  }))
}

const { pollie } = Astro.props as { pollie: PollieData }

const allPollies = await getCollection("pollies")
const pollieOptions = allPollies
  .map((p: { data: PollieData }) => ({
    slug: p.data.slug,
    name: p.data.name,
    party: p.data.party,
    house: p.data.house,
    division: p.data.division,
    state: p.data.state,
  }))
  .sort((a: { name: string }, b: { name: string }) => a.name.localeCompare(b.name))
---

<BaseLayout title={pollie.name}>
  <PollieSearch pollies={pollieOptions} client:load />
  <PollieHeader
    name={pollie.name}
    division={pollie.division}
    state={pollie.state}
    party={pollie.party}
    house={pollie.house}
    leftOfficeDate={formatDate(pollie.ceasedDate)}
    leftOfficeAgo={timeAgo(pollie.ceasedDate)}
    photoUrl={pollie.photoUrl}
  />
  <GigList gigs={pollie.gigs} />
</BaseLayout>
