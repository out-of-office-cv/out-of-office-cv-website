---
import type { Gig } from "../types"
import { formatISODate, sortGigsForDisplay } from "../utils"
import PollieBadge from "./PollieBadge.astro"

interface Props {
  gigs: Gig[]
}

const { gigs } = Astro.props
const sortedGigs = sortGigsForDisplay(gigs)

function getDateRange(gig: Gig): string {
  const hasEnd = gig.end_date && gig.end_date !== "unknown" && gig.end_date !== "present"
  const hasStart = gig.start_date && gig.start_date !== "unknown"
  if (hasStart) {
    return hasEnd
      ? `${formatISODate(gig.start_date!)} – ${formatISODate(gig.end_date!)}`
      : `${formatISODate(gig.start_date!)} – present`
  }
  return hasEnd ? `until ${formatISODate(gig.end_date!)}` : ""
}

function getHostname(url: string): string {
  try {
    return new URL(url).hostname
  } catch {
    return url
  }
}
---

<div class="gig-section">
  <h2>Post-office roles</h2>
  {sortedGigs.length === 0 ? (
    <p class="no-gigs">
      No out-of-office gigs found yet. Know of one?
      <a href="/contribute">Help us add it.</a>
    </p>
  ) : (
    <ul class="gig-list">
      {sortedGigs.map((gig) => (
        <li class:list={["gig-card", !gig.verified_by && "gig-card-unverified"]}>
          <div class="gig-role">
            {gig.role}
            {!gig.verified_by && (
              <span class="unverified-label" title="This gig has not been human-verified yet">Unverified</span>
            )}
          </div>
          <div class="gig-organisation">{gig.organisation}</div>
          <div class="gig-meta">
            <PollieBadge variant="category">{gig.category}</PollieBadge>
            {getDateRange(gig) && (
              <span class="gig-dates">{getDateRange(gig)}</span>
            )}
          </div>
          <div class="gig-sources">
            <span>{gig.sources.length === 1 ? "Source: " : "Sources: "}</span>
            {gig.sources.map((source, i) => (
              <>
                <a
                  href={source}
                  target="_blank"
                  rel="noopener"
                  class="source-link"
                >
                  {getHostname(source)}
                </a>
                {i < gig.sources.length - 1 && ", "}
              </>
            ))}
          </div>
        </li>
      ))}
    </ul>
  )}
</div>

<style>
  .gig-section h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .gig-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  }

  .gig-card {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg-soft);
  }

  .gig-card-unverified {
    opacity: 0.6;
  }

  .gig-role {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text-1);
    margin-bottom: 0.25rem;
  }

  .unverified-label {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-2);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    padding: 0.0625rem 0.375rem;
    border-radius: 3px;
    margin-left: 0.5rem;
    vertical-align: middle;
  }

  .gig-organisation {
    color: var(--color-text-1);
    margin-bottom: 0.5rem;
  }

  .gig-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .gig-dates {
    color: var(--color-text-2);
    font-size: 0.875rem;
  }

  .gig-sources {
    font-size: 0.8rem;
    color: var(--color-text-3);
  }

  .gig-sources a {
    color: var(--color-brand-1);
    text-decoration: none;
  }

  .gig-sources a:hover {
    text-decoration: underline;
  }

  .source-link {
    margin-right: 0.25rem;
  }

  .no-gigs {
    color: var(--color-text-2);
    font-style: italic;
  }

  .no-gigs a {
    color: var(--color-brand-1);
  }
</style>
