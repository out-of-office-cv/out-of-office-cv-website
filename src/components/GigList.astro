---
import type { Gig } from "../types"
import { formatISODate, sortGigsForDisplay } from "../utils"
import PollieBadge from "./PollieBadge.astro"

interface Props {
  gigs: Gig[]
}

const { gigs } = Astro.props
const sortedGigs = sortGigsForDisplay(gigs)

function getDateRange(gig: Gig): string {
  const hasEnd = gig.end_date && gig.end_date !== "unknown" && gig.end_date !== "present"
  const hasStart = gig.start_date && gig.start_date !== "unknown"
  if (hasStart) {
    return hasEnd
      ? `${formatISODate(gig.start_date!)} – ${formatISODate(gig.end_date!)}`
      : `${formatISODate(gig.start_date!)} – present`
  }
  return hasEnd ? `until ${formatISODate(gig.end_date!)}` : ""
}

function getHostname(url: string): string {
  try {
    return new URL(url).hostname.replace(/^www\./, "")
  } catch {
    return url
  }
}
---

<section class="gig-section" aria-labelledby="post-office-heading">
  <h2 id="post-office-heading">Post-office roles</h2>

  {sortedGigs.length === 0 ? (
    <p class="no-gigs">
      <em>No post-office roles recorded yet.</em>
      {" "}
      <a href="/contribute">Know of one? Help us add it.</a>
    </p>
  ) : (
    <ol class="gig-list">
      {sortedGigs.map((gig) => (
        <li class:list={["gig", !gig.verified_by && "gig-unverified"]}>
          <div class="gig-headline">
            <span class="gig-role">{gig.role}</span>
            <span class="gig-at">at</span>
            <span class="gig-org">{gig.organisation}</span>
            {!gig.verified_by && (
              <span class="unverified-tag" title="This role has not been human-verified yet">
                · unverified
              </span>
            )}
          </div>
          <div class="gig-meta">
            <PollieBadge variant="category">{gig.category}</PollieBadge>
            {getDateRange(gig) && (
              <span class="gig-dates">{getDateRange(gig)}</span>
            )}
          </div>
          <div class="gig-sources">
            <span class="caps sources-label">
              {gig.sources.length === 1 ? "Source" : "Sources"}
            </span>
            <span class="sources-list">
              {gig.sources.map((source, i) => (
                <>
                  <a
                    href={source}
                    target="_blank"
                    rel="noopener"
                    class="source-link"
                  >
                    {getHostname(source)}
                  </a>
                  {i < gig.sources.length - 1 && <span class="source-sep">·</span>}
                </>
              ))}
            </span>
          </div>
        </li>
      ))}
    </ol>
  )}
</section>

<style>
  .gig-section {
    margin-top: var(--space-xl);
  }

  .gig-section h2 {
    margin-top: 0;
    margin-bottom: var(--space-lg);
  }

  .no-gigs {
    font-family: var(--font-serif-stack);
    font-size: 1.05rem;
    color: var(--color-ink-2);
    max-width: var(--measure-reading);
  }

  .gig-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .gig {
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--color-rule);
    display: grid;
    gap: var(--space-xs);
    max-width: var(--measure-wide);
  }

  .gig:last-child {
    border-bottom: 1px solid var(--color-rule);
  }

  .gig-unverified {
    opacity: 0.78;
  }

  .gig-headline {
    font-family: var(--font-serif-stack);
    font-size: 1.2rem;
    line-height: 1.35;
    color: var(--color-ink);
    text-wrap: pretty;
  }

  .gig-role {
    font-weight: 600;
  }

  .gig-at {
    color: var(--color-ink-3);
    font-style: italic;
    margin: 0 0.25em;
    font-size: 0.95em;
  }

  .gig-org {
    color: var(--color-ink);
  }

  .unverified-tag {
    font-family: var(--font-sans-stack);
    font-size: var(--text-meta);
    font-style: italic;
    color: var(--color-ink-3);
    margin-left: 0.3rem;
    font-weight: 400;
  }

  .gig-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-sans-stack);
    font-size: var(--text-meta);
  }

  .gig-dates {
    color: var(--color-ink-2);
    font-variant-numeric: tabular-nums lining-nums;
    font-feature-settings: "tnum", "lnum";
  }

  .gig-sources {
    font-family: var(--font-sans-stack);
    font-size: var(--text-meta);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-xs);
    color: var(--color-ink-3);
  }

  .sources-label {
    color: var(--color-ink-3);
  }

  .sources-list {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.5rem;
    align-items: baseline;
  }

  .source-link {
    color: var(--color-accent);
    font-variant-numeric: lining-nums;
  }

  .source-sep {
    color: var(--color-ink-3);
  }
</style>
