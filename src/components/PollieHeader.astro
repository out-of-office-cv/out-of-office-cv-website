---
import type { House } from "../types"
import PollieBadge from "./PollieBadge.astro"

interface Props {
  name: string
  division: string
  state: string
  party: string
  house: House
  leftOfficeDate: string
  leftOfficeAgo: string
  photoUrl?: string
}

const { name, division, state, party, house, leftOfficeDate, leftOfficeAgo, photoUrl } = Astro.props
---

<header class="pollie-masthead">
  <div class="masthead-grid">
    {photoUrl && (
      <div class="portrait-frame">
        <img
          src={photoUrl}
          alt={`Portrait of ${name}`}
          class="portrait"
          loading="eager"
        />
      </div>
    )}
    <div class="info">
      <h1 class="pollie-name">{name}</h1>
      <div class="markers">
        <PollieBadge variant="party" party={party}>
          {party}
        </PollieBadge>
        <PollieBadge variant="house" house={house}>
          {house === "senate" ? "Senator" : "MP"}
        </PollieBadge>
      </div>
      <dl class="meta">
        {division && (
          <div class="meta-row">
            <dt class="caps">Electorate</dt>
            <dd>{division}</dd>
          </div>
        )}
        <div class="meta-row">
          <dt class="caps">State</dt>
          <dd>{state}</dd>
        </div>
        {leftOfficeDate && (
          <div class="meta-row">
            <dt class="caps">Left office</dt>
            <dd>
              {leftOfficeDate}
              <span class="meta-qualifier">({leftOfficeAgo})</span>
            </dd>
          </div>
        )}
      </dl>
    </div>
  </div>
</header>

<style>
  .pollie-masthead {
    padding-bottom: var(--space-xl);
    margin-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-rule);
  }

  .masthead-grid {
    display: grid;
    gap: var(--space-lg) var(--space-xl);
    grid-template-columns: 1fr;
  }

  @media (width >= 32rem) {
    .masthead-grid {
      grid-template-columns: 8rem 1fr;
      align-items: start;
    }
  }

  .portrait-frame {
    /* Reserve slot; behaves well when photo missing */
  }

  .portrait {
    width: 100%;
    max-width: 9rem;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    background: var(--color-paper-deep);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-sm);
    display: block;
  }

  .info {
    min-width: 0;
  }

  .pollie-name {
    margin: 0 0 var(--space-sm);
    font-feature-settings: "kern", "liga", "lnum";
  }

  .markers {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-lg);
  }

  .meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, max-content));
    gap: var(--space-md) var(--space-xl);
    margin: 0;
    font-family: var(--font-sans-stack);
  }

  .meta-row {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .meta-row dt {
    font-size: var(--text-caps);
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--color-ink-3);
  }

  .meta-row dd {
    margin: 0;
    font-size: var(--text-body);
    color: var(--color-ink);
    font-feature-settings: "kern", "liga", "lnum", "tnum";
  }

  .meta-qualifier {
    color: var(--color-ink-3);
    font-style: italic;
    margin-left: 0.2rem;
  }
</style>
