---
const currentPath = Astro.url.pathname
---

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-brand">Out of Office CV</a>
    <ul class="nav-links">
      <li>
        <a href="/" class:list={[{ active: currentPath === "/" }]}>Home</a>
      </li>
      <li>
        <a
          href="/about"
          class:list={[{ active: currentPath === "/about" }]}
        >
          About
        </a>
      </li>
      <li>
        <a
          href="/contribute"
          class:list={[{ active: currentPath === "/contribute" }]}
        >
          Contribute
        </a>
      </li>
    </ul>
  </div>
</nav>

<style>
  nav {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-text-1);
    text-decoration: none;
  }

  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1.5rem;
  }

  .nav-links a {
    color: var(--color-text-2);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--color-brand-1);
  }
</style>
