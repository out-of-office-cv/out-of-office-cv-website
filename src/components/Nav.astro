---
const currentPath = Astro.url.pathname
---

<header class="masthead">
  <div class="masthead-inner">
    <a href="/" class="wordmark-link" aria-label="Out of Office CV — home">
      <span class="wordmark">Out of Office CV</span>
      <span class="tagline">
        A record of what Australian ex-parliamentarians do next
      </span>
    </a>
    <nav aria-label="Primary">
      <ul class="nav-links">
        <li>
          <a href="/" class:list={[{ active: currentPath === "/" }]}>
            Directory
          </a>
        </li>
        <li>
          <a
            href="/analytics"
            class:list={[{ active: currentPath === "/analytics" }]}
          >
            Analytics
          </a>
        </li>
        <li>
          <a href="/about" class:list={[{ active: currentPath === "/about" }]}>
            About
          </a>
        </li>
        <li>
          <a
            href="/contribute"
            class:list={[{ active: currentPath === "/contribute" }]}
          >
            Contribute
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .masthead {
    background: var(--color-paper);
    border-bottom: 1px solid var(--color-rule);
  }

  .masthead-inner {
    max-width: 78rem;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-lg) var(--space-lg);
    display: grid;
    gap: var(--space-md);
    grid-template-columns: 1fr;
  }

  @media (width >= 48rem) {
    .masthead-inner {
      grid-template-columns: 1fr auto;
      align-items: end;
      padding-inline: var(--space-2xl);
      padding-top: var(--space-2xl);
    }
  }

  .wordmark-link {
    color: var(--color-ink);
    text-decoration: none;
    display: block;
    line-height: var(--lh-display);
  }

  .wordmark-link:hover {
    color: var(--color-ink);
  }

  .wordmark-link:hover .wordmark {
    color: var(--color-accent-hover);
  }

  .wordmark {
    font-family: var(--font-serif-stack);
    font-size: var(--text-masthead);
    font-weight: 500;
    letter-spacing: -0.018em;
    color: var(--color-ink);
    font-feature-settings: "kern", "liga", "lnum";
    display: block;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .tagline {
    display: block;
    font-family: var(--font-serif-stack);
    font-style: italic;
    font-size: var(--text-meta);
    color: var(--color-ink-3);
    margin-top: var(--space-2xs);
    line-height: 1.4;
  }

  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-xl);
    align-items: baseline;
  }

  .nav-links a {
    font-family: var(--font-sans-stack);
    font-size: var(--text-caps);
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--color-ink-2);
    text-decoration: none;
    padding-block: var(--space-2xs);
    border-bottom: 1px solid transparent;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }

  .nav-links a:hover {
    color: var(--color-ink);
    border-bottom-color: var(--color-ink-2);
  }

  .nav-links a.active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
</style>
