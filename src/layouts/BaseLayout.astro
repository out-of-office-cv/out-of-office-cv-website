---
import "../styles/global.css"
import { Font } from "astro:assets"
import Nav from "../components/Nav.astro"
import SiteFooter from "../components/SiteFooter.astro"

interface Props {
  title?: string
  description?: string
}

const { title, description } = Astro.props
const siteTitle = title ? `${title} | Out of Office CV` : "Out of Office CV"
const siteDescription =
  description ||
  "A record of what Australian ex-parliamentarians do next."
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <link rel="canonical" href="https://www.outofoffice.cv" />
    <Font cssVariable="--font-serif" preload />
    <Font cssVariable="--font-sans" preload />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>

<style>
  main {
    max-width: 78rem;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-lg) var(--space-3xl);
    width: 100%;
  }

  @media (width >= 60rem) {
    main {
      padding-inline: var(--space-2xl);
      padding-top: var(--space-2xl);
    }
  }
</style>
